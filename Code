<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Task 3 – IoT Data Monitoring Dashboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --bg: #f8f7f4;
    --surface: #ffffff;
    --border: #e2ddd8;
    --text: #1a1a1a;
    --muted: #8a8580;
    --accent: #2563eb;
    --accent2: #16a34a;
    --accent3: #dc2626;
    --accent4: #9333ea;
    --warm: #ea580c;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
  }

  .topbar {
    background: var(--text); color: #fff;
    padding: 0.85rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .topbar-left { display: flex; align-items: center; gap: 16px; }
  .topbar h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.3px; }
  .live-badge {
    display: flex; align-items: center; gap: 6px;
    font-family: 'DM Mono', monospace; font-size: 0.72rem;
    background: rgba(22,163,74,0.2); color: #4ade80;
    padding: 3px 10px; border-radius: 20px;
  }
  .live-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #4ade80; animation: blink 1s infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .topbar-right {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem; color: rgba(255,255,255,0.5);
  }
  #clockDisplay { color: rgba(255,255,255,0.9); }

  .ctrlbar {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 0.6rem 2rem;
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
  }
  .ctrl-btn {
    font-family: 'DM Mono', monospace; font-size: 0.75rem;
    padding: 5px 14px; border-radius: 6px;
    border: 1.5px solid var(--border);
    background: var(--surface); color: var(--text);
    cursor: pointer; transition: all 0.15s;
  }
  .ctrl-btn:hover { border-color: var(--text); }
  .ctrl-btn.active { background: var(--text); color: #fff; border-color: var(--text); }
  .ctrl-sep { width: 1px; height: 20px; background: var(--border); }

  .layout {
    display: grid; grid-template-columns: 280px 1fr;
    gap: 0; min-height: calc(100vh - 100px);
  }

  .sidebar {
    border-right: 1px solid var(--border); padding: 1.5rem;
    display: flex; flex-direction: column; gap: 1rem;
    background: var(--surface);
  }
  .sidebar-title {
    font-family: 'DM Mono', monospace; font-size: 0.68rem;
    color: var(--muted); letter-spacing: 2px; text-transform: uppercase;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
  }

  .metric-card {
    border: 1.5px solid var(--border); border-radius: 12px;
    padding: 1rem 1.25rem; position: relative; overflow: hidden;
    transition: border-color 0.2s;
  }
  .metric-card:hover { border-color: var(--text); }
  .metric-label {
    font-family: 'DM Mono', monospace; font-size: 0.68rem;
    color: var(--muted); letter-spacing: 1.5px;
    text-transform: uppercase; margin-bottom: 0.4rem;
  }
  .metric-value { font-size: 2rem; font-weight: 800; line-height: 1; }
  .metric-unit { font-size: 1rem; font-weight: 400; color: var(--muted); }
  .metric-footer { margin-top: 0.5rem; font-size: 0.78rem; color: var(--muted); }
  .metric-bar {
    height: 4px; background: var(--border);
    border-radius: 2px; margin-top: 0.75rem;
  }
  .metric-bar-fill { height: 100%; border-radius: 2px; transition: width 0.5s; }

  .mc-temp .metric-value { color: var(--warm); }
  .mc-temp .metric-bar-fill { background: var(--warm); }
  .mc-hum .metric-value { color: var(--accent); }
  .mc-hum .metric-bar-fill { background: var(--accent); }
  .mc-mot .metric-value { color: var(--accent4); }
  .mc-mot .metric-bar-fill { background: var(--accent4); }

  .alert-feed { flex: 1; min-height: 0; }
  .alert-item {
    padding: 0.6rem 0.75rem; border-radius: 8px; margin-bottom: 6px;
    font-size: 0.78rem; font-family: 'DM Mono', monospace;
    line-height: 1.4; border: 1px solid;
  }
  .alert-ok {
    background: rgba(22,163,74,0.06);
    border-color: rgba(22,163,74,0.2); color: #16a34a;
  }
  .alert-warn {
    background: rgba(234,88,12,0.06);
    border-color: rgba(234,88,12,0.2); color: var(--warm);
  }
  .alert-danger {
    background: rgba(220,38,38,0.06);
    border-color: rgba(220,38,38,0.2); color: var(--accent3);
  }

  .main-content {
    padding: 1.5rem;
    display: flex; flex-direction: column; gap: 1.5rem;
  }

  .chart-card {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 14px; padding: 1.25rem;
  }
  .chart-header {
    display: flex; align-items: center;
    justify-content: space-between; margin-bottom: 1rem;
  }
  .chart-header h3 { font-size: 0.9rem; font-weight: 700; }
  .chart-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem; color: var(--muted);
  }

  .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

  .data-table-card {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 14px; overflow: hidden;
  }
  .dt-header {
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .dt-header h3 { font-size: 0.9rem; font-weight: 700; }
  table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  thead th {
    padding: 0.6rem 1rem; text-align: left;
    font-family: 'DM Mono', monospace; font-size: 0.68rem;
    color: var(--muted); letter-spacing: 1.5px; text-transform: uppercase;
    background: var(--bg); border-bottom: 1px solid var(--border);
  }
  tbody tr { border-bottom: 1px solid rgba(226,221,216,0.5); }
  tbody tr:hover { background: var(--bg); }
  tbody td {
    padding: 0.55rem 1rem; color: var(--text);
    font-family: 'DM Mono', monospace;
  }
  .td-temp  { color: var(--warm);    font-weight: 500; }
  .td-hum   { color: var(--accent);  font-weight: 500; }
  .td-motion-y { color: var(--accent4); font-weight: 500; }
  .td-time  { color: var(--muted);   font-size: 0.75rem; }

  .status-pill {
    display: inline-block; padding: 2px 8px; border-radius: 20px;
    font-family: 'DM Mono', monospace; font-size: 0.68rem; font-weight: 500;
  }
  .sp-ok    { background: rgba(22,163,74,0.1);  color: #16a34a; }
  .sp-warn  { background: rgba(234,88,12,0.1);  color: var(--warm); }
  .sp-alert { background: rgba(220,38,38,0.1);  color: var(--accent3); }

  .footer {
    background: var(--text); color: rgba(255,255,255,0.4);
    padding: 0.75rem 2rem;
    font-family: 'DM Mono', monospace; font-size: 0.7rem;
    display: flex; justify-content: space-between;
  }
  .footer span { color: rgba(255,255,255,0.8); }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { border-right: none; border-bottom: 1px solid var(--border); }
    .charts-row { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <h1>IoT Monitoring Dashboard</h1>
    <div class="live-badge">
      <div class="live-dot"></div>LIVE
    </div>
  </div>
  <div class="topbar-right">
    <span id="clockDisplay">--:--:--</span>
    &nbsp;·&nbsp; DECODE LAB TASK 3
  </div>
</div>

<div class="ctrlbar">
  <button class="ctrl-btn active" onclick="toggleSim(this)">
    ⏵ Streaming
  </button>
  <div class="ctrl-sep"></div>
  <button class="ctrl-btn" onclick="setView('1m')">1 min</button>
  <button class="ctrl-btn active" onclick="setView('5m')">5 min</button>
  <button class="ctrl-btn" onclick="setView('all')">All</button>
  <div class="ctrl-sep"></div>
  <span style="font-family:'DM Mono',monospace;font-size:0.75rem;
    color:var(--muted)" id="readingsLabel">0 readings</span>
</div>

<div class="layout">

  <div class="sidebar">
    <div class="sidebar-title">Live Sensors</div>

    <div class="metric-card mc-temp">
      <div class="metric-label">Temperature</div>
      <div class="metric-value" id="sbTemp">
        --<span class="metric-unit">°C</span>
      </div>
      <div class="metric-footer" id="sbTempRange">Min/Max: --</div>
      <div class="metric-bar">
        <div class="metric-bar-fill" id="sbTempBar" style="width:0%"></div>
      </div>
    </div>

    <div class="metric-card mc-hum">
      <div class="metric-label">Humidity</div>
      <div class="metric-value" id="sbHum">
        --<span class="metric-unit">%</span>
      </div>
      <div class="metric-footer" id="sbHumRange">Min/Max: --</div>
      <div class="metric-bar">
        <div class="metric-bar-fill" id="sbHumBar" style="width:0%"></div>
      </div>
    </div>

    <div class="metric-card mc-mot">
      <div class="metric-label">Motion Events</div>
      <div class="metric-value" id="sbMotion">0</div>
      <div class="metric-footer" id="sbMotionPct">0% detection rate</div>
      <div class="metric-bar">
        <div class="metric-bar-fill" id="sbMotBar" style="width:0%"></div>
      </div>
    </div>

    <div class="sidebar-title" style="margin-top:0.5rem">Alerts</div>
    <div class="alert-feed" id="alertFeed">
      <div class="alert-item alert-ok">System online, awaiting data…</div>
    </div>
  </div>

  <div class="main-content">

    <div class="chart-card">
      <div class="chart-header">
        <h3>Temperature Over Time</h3>
        <span class="chart-meta" id="tempChartMeta">—</span>
      </div>
      <div style="position:relative;height:180px">
        <canvas id="tempChart" role="img"
          aria-label="Line chart showing temperature readings over time">
          Temperature chart loading...
        </canvas>
      </div>
    </div>

    <div class="charts-row">
      <div class="chart-card">
        <div class="chart-header">
          <h3>Humidity %</h3>
          <span class="chart-meta" id="humChartMeta">—</span>
        </div>
        <div style="position:relative;height:160px">
          <canvas id="humChart" role="img"
            aria-label="Humidity readings over time">
            Humidity chart loading...
          </canvas>
        </div>
      </div>

      <div class="chart-card">
        <div class="chart-header">
          <h3>Motion Detection</h3>
          <span class="chart-meta" id="motChartMeta">—</span>
        </div>
        <div style="position:relative;height:160px">
          <canvas id="motChart" role="img"
            aria-label="Motion detection events per reading">
            Motion chart loading...
          </canvas>
        </div>
      </div>
    </div>

    <div class="data-table-card">
      <div class="dt-header">
        <h3>Recent Readings</h3>
        <span style="font-family:'DM Mono',monospace;font-size:0.72rem;
          color:var(--muted)" id="tableCount">0 records</span>
      </div>
      <div style="overflow:auto;max-height:220px">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Time</th>
              <th>Temp (°C)</th>
              <th>Humidity (%)</th>
              <th>Motion</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr>
              <td colspan="6"
                style="text-align:center;color:var(--muted);padding:2rem">
                Starting simulation…
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<div class="footer">
  <span>DECODE LAB INTERNSHIP</span>
  &nbsp;·&nbsp; Task 3: IoT Data Monitoring Dashboard
  <span id="uptimeLabel">Uptime: 0s</span>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js">
</script>
<script>
  const MAX_POINTS = 30;
  let labels=[], tempData=[], humData=[], motData=[];
  let allRecords=[];
  let motCount=0, totalCount=0;
  let running=true;
  let startTime=Date.now();

  setInterval(() => {
    document.getElementById('clockDisplay').textContent =
      new Date().toLocaleTimeString('en-IN', { hour12:false });
    const secs = Math.floor((Date.now() - startTime) / 1000);
    document.getElementById('uptimeLabel').textContent =
      'Uptime: ' + (secs < 60
        ? secs + 's'
        : Math.floor(secs/60) + 'm ' + (secs%60) + 's');
  }, 1000);

  const chartOpts = (color, label, yMin, yMax) => ({
    responsive: true, maintainAspectRatio: false,
    animation: { duration: 300 },
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: ctx => label+': '+ctx.parsed.y } }
    },
    scales: {
      x: {
        ticks: { font:{family:'DM Mono',size:10},
          color:'#8a8580', maxTicksLimit:6 },
        grid: { color:'rgba(0,0,0,0.04)' },
        border: { color:'rgba(0,0,0,0.1)' }
      },
      y: {
        min: yMin, max: yMax,
        ticks: { font:{family:'DM Mono',size:10},
          color:'#8a8580', maxTicksLimit:5 },
        grid: { color:'rgba(0,0,0,0.04)' },
        border: { color:'rgba(0,0,0,0.1)' }
      }
    }
  });

  const tempChart = new Chart(document.getElementById('tempChart'), {
    type: 'line',
    data: { labels, datasets: [{
      label:'Temp', data: tempData,
      borderColor:'#ea580c',
      backgroundColor:'rgba(234,88,12,0.07)',
      borderWidth:2, tension:0.4, fill:true,
      pointRadius:2, pointHoverRadius:5,
      pointBackgroundColor:'#ea580c'
    }]},
    options: chartOpts('#ea580c','°C',10,50)
  });

  const humChart = new Chart(document.getElementById('humChart'), {
    type: 'line',
    data: { labels, datasets: [{
      label:'Hum', data: humData,
      borderColor:'#2563eb',
      backgroundColor:'rgba(37,99,235,0.07)',
      borderWidth:2, tension:0.4, fill:true,
      pointRadius:2, pointHoverRadius:5,
      pointBackgroundColor:'#2563eb'
    }]},
    options: chartOpts('#2563eb','%',0,100)
  });

  const motChart = new Chart(document.getElementById('motChart'), {
    type: 'bar',
    data: { labels, datasets: [{
      label:'Motion', data: motData,
      backgroundColor: motData.map(v =>
        v ? 'rgba(147,51,234,0.7)' : 'rgba(147,51,234,0.15)'),
      borderRadius: 4
    }]},
    options: {
      responsive:true, maintainAspectRatio:false,
      animation:{ duration:300 },
      plugins:{ legend:{ display:false } },
      scales:{
        x:{ ticks:{font:{family:'DM Mono',size:10},
              color:'#8a8580', maxTicksLimit:6},
